PORT=3002

# Twitter OAuth2 credentials (create at developer.x.com)
# Callback URL: http://localhost:3002/api/twitter/callback
# Scopes: tweet.read users.read offline.access
TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here

# OPNet
OPNET_RPC_URL=https://testnet.opnet.org

# CORS allowed frontend origin
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_PROD=https://devtech.pages.dev
